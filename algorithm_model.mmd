flowchart TD

    %% ── INPUT ────────────────────────────────────────────────────────────────
    subgraph HUMAN_IN["👤  Human Input"]
        Q["Natural language query"]
        IFACE["CLI  ·  Streamlit UI"]
    end

    %% ── PARSE ────────────────────────────────────────────────────────────────
    subgraph PARSE_AGENT["🤖  Parse Agent  —  Gemini 3 Flash  (API Call 1)"]
        PARSE_FN["parse_preferences()"]
        PREFS["genre · mood · energy · valence · BPM"]
    end

    %% ── HUMAN REVIEW ①  ──────────────────────────────────────────────────────
    HCHECK(["👤  Review ①\nVerify parsed prefs — re-query if wrong"])

    %% ── GUARDRAILS ───────────────────────────────────────────────────────────
    subgraph GUARDRAILS["🛡️  Guardrails  ·  src/guardrails.py"]
        VALID["validate_user_prefs()\n30 genres · 14 moods · numeric ranges"]
        WARN["⚠️  Invalid field stripped"]
    end

    %% ── RETRIEVAL ────────────────────────────────────────────────────────────
    subgraph RETRIEVAL["⚙️  Retrieval Engine  ·  src/recommender.py"]
        CATALOG[("📁  songs.csv\n203 songs · 30 genres")]
        SCORER["score_song()\n7-factor weighted score  ·  max 6.50 pts"]
        RECOMMENDER["recommend_songs()\nAll 203 songs scored → Top 5"]
        TOP5["Ranked results + per-factor breakdown"]
    end

    %% ── RAG EXPLAIN ──────────────────────────────────────────────────────────
    subgraph RAG["🤖  Explain Agent  —  Gemini 3 Flash  (API Call 2  ·  RAG)"]
        RESCORE["Re-score top 5 → List of reason strings"]
        EXPLAIN["generate_rag_explanation()\nContext: query + retrieved songs + scores"]
        STORY["Grounded 3–5 sentence narrative"]
    end

    %% ── OUTPUT ───────────────────────────────────────────────────────────────
    subgraph OUTPUT["👤  Output  &  Evaluation"]
        TABLE["Ranked Table  ·  #1–5 · Score · Breakdown"]
        TEXT["AI DJ Explanation"]
        EVAL(["👤  Evaluate ②\nRe-query if unsatisfied"])
    end

    %% ── TESTING & RELIABILITY ────────────────────────────────────────────────
    subgraph RELIABILITY["🧪  Testing  &  Reliability"]
        LOG["📝  Logger\nstdout  ·  recommender.log"]
        T1["✅  Consistency"]
        T2["✅  Score Regression"]
        T3["✅  Validate Energy"]
        T4["✅  Validate Valence"]
        T5["✅  Validate Accept"]
        T6["✅  OOP Returns k"]
        T7["✅  OOP Ranks by Score"]
        DEV(["👤  Dev runs pytest  ③"])
    end

    %% ── PRIMARY DATA FLOW ────────────────────────────────────────────────────
    Q --> IFACE --> PARSE_FN --> PREFS
    PREFS -->|"Displayed to user"| HCHECK
    HCHECK -->|"Correct"| VALID
    HCHECK -->|"Wrong — re-enter"| Q
    VALID -->|"Passes"| RECOMMENDER
    VALID -->|"ValueError"| WARN --> RECOMMENDER
    CATALOG --> SCORER --> RECOMMENDER --> TOP5
    TOP5 --> TABLE
    TOP5 --> RESCORE --> EXPLAIN --> STORY
    Q -.->|"Original query"| EXPLAIN
    TABLE --> TEXT
    STORY --> TEXT --> EVAL
    EVAL -->|"Re-query"| Q

    %% ── LOGGING SIDE-CHANNEL ─────────────────────────────────────────────────
    PARSE_FN -.-> LOG
    RECOMMENDER -.-> LOG
    EXPLAIN -.-> LOG

    %% ── TESTING HOOKS ────────────────────────────────────────────────────────
    T1 & T6 & T7 -.->|"verify"| RECOMMENDER
    T2 -.->|"verify"| SCORER
    T3 & T4 & T5 -.->|"verify"| VALID
    DEV -->|"runs"| T1 & T2 & T3 & T4 & T5 & T6 & T7

