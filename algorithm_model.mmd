    classDef human  fill:#dbeafe,stroke:#3b82f6,stroke-width:2px,color:#1e3a8a
    classDef llm    fill:#ede9fe,stroke:#8b5cf6,stroke-width:2px,color:#4c1d95
    classDef engine fill:#dcfce7,stroke:#22c55e,stroke-width:2px,color:#14532d
    classDef data   fill:#fef9c3,stroke:#eab308,stroke-width:2px,color:#713f12
    classDef guard  fill:#fee2e2,stroke:#ef4444,stroke-width:2px,color:#7f1d1d
    classDef test   fill:#ccfbf1,stroke:#14b8a6,stroke-width:2px,color:#134e4a

    class Q,IFACE,HCHECK,EVAL,DEV human
    class PARSE_FN,PREFS,EXPLAIN,STORY,RESCORE llm
    class SCORER,RECOMMENDER,TOP5 engine
    class CATALOG data
    class VALID,WARN guard
    class T1,T2,T3,T4,T5,T6,T7,LOG test
